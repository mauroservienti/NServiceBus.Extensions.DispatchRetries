{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "nuget": {
    "fileMatch": ["src/.*\\.csproj$", "targets/.*\\.csproj$", "src/.*\\.props$", "targets/.*\\.props$"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
